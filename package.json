{
  "name": "viewrig",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Engine-agnostic camera pose solver and rig algorithms for games.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "api:check": "node scripts/api-report.mjs --check",
    "api:report": "node scripts/api-report.mjs --write",
    "build": "tsc -b",
    "boundary:check": "node scripts/check-boundaries.mjs",
    "docs:api": "typedoc --options typedoc.json",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:browser": "pnpm --dir examples/three-orbit-playground build && pnpm --dir examples/three-orbit-playground smoke",
    "test:watch": "vitest",
    "docs:check": "node scripts/check-docs.mjs"
  },
  "devDependencies": {
    "@types/node": "24.13.2",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
