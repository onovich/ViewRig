{
  "name": "viewrig",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Engine-agnostic camera pose solver and rig algorithms for games.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onovich/ViewRig.git"
  },
  "bugs": {
    "url": "https://github.com/onovich/ViewRig/issues"
  },
  "homepage": "https://github.com/onovich/ViewRig#readme",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "api:check": "pnpm build && node scripts/api-extractor.mjs --check",
    "api:report": "pnpm build && node scripts/api-extractor.mjs --write",
    "build": "tsc -b",
    "boundary:check": "node scripts/check-boundaries.mjs",
    "docs:api": "typedoc --options typedoc.json",
    "changeset:status": "changeset status --verbose",
    "changeset:dry-run": "node scripts/changesets-dry-run.mjs",
    "package:dry-run": "node scripts/package-dry-run.mjs",
    "package:consumer-smoke": "node scripts/package-consumer-smoke.mjs",
    "release:dry-run": "pnpm build && pnpm package:dry-run && pnpm changeset:dry-run",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run",
    "test:browser": "pnpm --dir examples/three-orbit-playground build && pnpm --dir examples/three-orbit-playground smoke",
    "test:watch": "vitest",
    "docs:check": "node scripts/check-docs.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@microsoft/api-extractor": "^7.58.9",
    "@types/node": "24.13.2",
    "playwright": "^1.61.0",
    "typedoc": "^0.28.19",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
