{
  "name": "@viewrig/testing",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Deterministic golden trace helpers and fake fixtures for ViewRig.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onovich/ViewRig.git",
    "directory": "packages/testing"
  },
  "bugs": {
    "url": "https://github.com/onovich/ViewRig/issues"
  },
  "homepage": "https://github.com/onovich/ViewRig#readme",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "README.md"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@viewrig/core": "workspace:*"
  }
}
