{
  "name": "@viewrig/adapter-three",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Structural Three-compatible camera adapter for ViewRig CameraState.",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onovich/ViewRig.git",
    "directory": "packages/adapter-three"
  },
  "bugs": {
    "url": "https://github.com/onovich/ViewRig/issues"
  },
  "homepage": "https://github.com/onovich/ViewRig#readme",
